{
  "name": "traffic-game",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "cd apps/server && pnpm prisma generate",
    "db:push": "cd apps/server && pnpm prisma db push",
    "db:studio": "cd apps/server && pnpm prisma studio",
    "db:migrate": "cd apps/server && pnpm prisma migrate dev"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.9.5",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
