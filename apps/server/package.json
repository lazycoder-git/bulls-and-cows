{
  "name": "@traffic/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/websocket": "^11.0.2",
    "@prisma/client": "^6.6.0",
    "@traffic/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.2",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.8",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.0.0",
    "prisma": "^6.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.6.0"
  }
}
